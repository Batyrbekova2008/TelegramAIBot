# ═══════════════════════════════════════════════════════════════════
# Telegram AI Bot — .env.example
# Скопируйте этот файл в .env и заполните значения
# ═══════════════════════════════════════════════════════════════════

# ── Required ────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your-telegram-bot-token-here
GROQ_API_KEY=gsk_your-groq-api-key-here

# ── Database (PostgreSQL) ────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chat-bot

# ── Redis ────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Groq model settings ──────────────────────────────────────────────
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MODEL_RPM=30
GROQ_MODEL_TPM=40000

# ── Tavily web search (Block 4, Task 19) — optional ──────────────────
# Get key: https://app.tavily.com/
TAVILY_API_KEY=

# ── MCP servers (Block 2) ─────────────────────────────────────────────
# Role for PostgreSQL MCP server: student | teacher | admin
MCP_PG_ROLE=teacher
# Bearer token for HTTP/SSE MCP server
MCP_BEARER_TOKEN=changeme-replace-in-production
MCP_SSE_PORT=8001

# ── Webhook mode (Block 4, Task 22) — optional ───────────────────────
# Leave empty to use long polling (default)
WEBHOOK_HOST=
WEBHOOK_SECRET=changeme-webhook-secret
WEBHOOK_PORT=8443
SSL_CERT=ssl/cert.pem
SSL_KEY=ssl/key.pem

# ── OpenTelemetry / Jaeger (Block 6) ─────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=telegram-ai-bot

# ── Grafana (Block 6, docker-compose) ────────────────────────────────
GRAFANA_PASSWORD=admin
